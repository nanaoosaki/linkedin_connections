{
  "manifest_version": 3,
  "name": "LinkedIn Connections Exporter",
  "version": "1.0.0",
  "description": "Export all your LinkedIn connections to a CSV file in one click. Name, headline, connected date, profile URL — no manual copying.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "icons": {
    "16":  "icon-16.png",
    "48":  "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icon-16.png",
      "48":  "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "content_scripts": [{
    "matches": [
      "https://www.linkedin.com/mynetwork/invite-connect/connections/",
      "https://www.linkedin.com/mynetwork/invite-connect/connections/*"
    ],
    "js": ["content.js"]
  }]
}
